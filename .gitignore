# =======================================================
# Visual Studio Core (Intellisense, Project Configs, Cache)
# =======================================================
.vs/
*.user
*.suo
*.opensdf
*.sdf
*.cache
*.db
*.opendsb
*.vot

# =======================================================
# Build Output Directories
# =======================================================
# Standard VS output folders
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
ARM/
ARM64/

# Intermediate files
*.obj
*.pdb
*.ipdb
*.iobj
*.ilk
*.lib
*.exp
*.log
*.tlog
*.lastbuildstate
*.idb

# Executables (unless you want to include pre-compiled binaries)
*.exe
*.dll

# =======================================================
# CUDA / NVIDIA Nsight Profiling Artifacts
# =======================================================
# Nsight Compute & Systems reports (can be very large)
*.ncu-rep
*.nsys-rep
*.nsight-report

# Legacy Visual Profiler files
*.nvvp
*.qdrep

# CUDA specific compile dumps (rare, but good to block)
*.cubin
*.fatbin

# =======================================================
# OS Specific
# =======================================================
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini