// Set the version and target
.version 7.0
.target sm_70
.address_size 64

// Kernel declaration
.visible .entry array_reverse (
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 n
)
{
    // Register declarations
    .reg .u64   %in_addr, %out_addr, %in_offset;
    .reg .u64   %out_offset, %current_addr;
    .reg .u32   %n, %i, %current_val;
    .reg .u32   %tmp, %rev_idx;
    .reg .pred  %loop_done;

    // Load parameters
    ld.param.u64  %in_addr, [in_ptr];
    ld.param.u64  %out_addr, [out_ptr];
    ld.param.u32  %n,  [n];

    // Initialize loop index
    mov.u32 %i, 0;

loop_start:

    // Check if loop should end
    setp.ge.u32  %loop_done, %i, %n;
    @%loop_done bra loop_end;

    // Read next value
    mul.wide.u32  %in_offset, %i, 4;
    add.u64       %current_addr, %in_addr, %in_offset;
    ld.global.u32 %current_val, [%current_addr];

    // Reverse index = n - 1 - i
    sub.u32 %tmp, %n, 1;
    sub.u32 %rev_idx, %tmp, %i;

    // Find address in output array
    mul.wide.u32   %out_offset, %rev_idx, 4;
    add.u64        %current_addr, %out_addr, %out_offset;
    st.global.u32  [%current_addr], %current_val;

    // Increment the index
    add.u32 %i, %i, 1;
    bra loop_start;

loop_end:
    ret;
}